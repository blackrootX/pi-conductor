{
  "name": "pi-conductor",
  "version": "0.1.0",
  "description": "A pi agent package providing multi-agent orchestration with basic commands",
  "keywords": [
    "pi-package",
    "agent-orchestration",
    "multi-agent",
    "pi-coding-agent",
    "agent-framework"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./parser": "./src/parser.ts",
    "./normalizer": "./src/normalizer.ts",
    "./errors": "./src/errors.ts",
    "./types": "./src/types.ts",
    "./discovery": "./src/discovery.ts",
    "./registry": "./src/registry.ts"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@mariozechner/pi-tui": "^0.61.1",
    "bun-types": "^1.3.11",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.61.1"
  },
  "files": [
    "src/",
    "agents/",
    "extensions/",
    "skills/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/blackrootX/pi-conductor"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "yaml": "^2.8.3"
  }
}

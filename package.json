{
  "name": "pi-conductor",
  "version": "0.1.0",
  "description": "A pi agent package providing multi-agent orchestration with basic commands",
  "keywords": [
    "pi-package",
    "agent-orchestration",
    "multi-agent",
    "pi-coding-agent",
    "agent-framework"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./parser": "./src/parser.ts",
    "./normalizer": "./src/normalizer.ts",
    "./errors": "./src/errors.ts"
  },
  "pi": {
    "extensions": ["./extensions"]
  },
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build": "tsc",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  },
  "files": [
    "src/",
    "agents/",
    "extensions/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/blackrootX/pi-conductor"
  },
  "author": "",
  "license": "MIT"
}

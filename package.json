{
  "name": "pi-conductor",
  "version": "0.1.0",
  "description": "A pi agent package for basic commands and multi-agent orchestration",
  "keywords": ["pi-package", "agent-orchestration"],
  "type": "module",
  "main": "src/index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./parser": "./src/parser.ts",
    "./normalizer": "./src/normalizer.ts",
    "./errors": "./src/errors.ts"
  },
  "pi": {
    "extensions": ["./extensions"]
  },
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build": "tsc",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "0.61.0",
    "@types/bun": "latest",
    "typescript": "^5.9.3",
    "yaml": "^2.8.1"
  },
  "files": [
    "src/",
    "agents/",
    "extensions/"
  ]
}
